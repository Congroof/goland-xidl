<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.leibuyun.xidl</id>
    <name>Xidl Language Support</name>
    <vendor>leibuyun</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- 文件类型注册 -->
        <fileType name="Xidl"
                  implementationClass="org.jetbrains.xidl.language.XidlFileType"
                  fieldName="INSTANCE"
                  language="Xidl"
                  extensions="xidl"/>
                  
        <!-- 语法高亮器 -->
        <lang.syntaxHighlighterFactory language="Xidl"
                                     implementationClass="org.jetbrains.xidl.language.highlighting.XidlSyntaxHighlighterFactory"/>

        <lang.parserDefinition
                language="Xidl"
                implementationClass="org.jetbrains.xidl.language.XidlParserDefinition"/>

        <!-- 代码注释器 -->
        <lang.commenter
                language="Xidl"
                implementationClass="org.jetbrains.xidl.language.commenter.XidlCommenter"/>

        <lang.braceMatcher language="Xidl"
                           implementationClass="org.jetbrains.xidl.language.brace.XidlBraceMatcher"/>

        <annotator
                language="Xidl"
                implementationClass="org.jetbrains.xidl.language.annotator.XidlAnnotator"/>

        <navbar implementation="org.jetbrains.xidl.language.XidlStructureAwareNavbar"/>

        <lang.foldingBuilder
                language="Xidl"
                implementationClass="org.jetbrains.xidl.language.folding.XidlFoldingBuilder"/>

        <psi.referenceContributor language="Xidl"
                                  implementation="org.jetbrains.xidl.language.reference.XidlReferenceContributor"/>
        
<!--        <lang.findUsagesProvider language="Xidl"-->
<!--                implementationClass="org.jetbrains.xidl.language.reference.XidlFindUsageProvider"/>-->

        <lang.elementManipulator forClass="org.jetbrains.xidl.language.psi.impl.XidlTypeReferenceImpl"
                               implementationClass="org.jetbrains.xidl.language.reference.XidlTypeReferenceManipulator"/>
    </extensions>
</idea-plugin>
