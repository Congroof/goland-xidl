<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.congroof.xidl</id>
    <name>Xidl Language</name>
    <vendor url="https://github.com/Congroof/goland-xidl">Congroof</vendor>

    <!-- version / description / change-notes 由 Gradle IntelliJ Platform Plugin
         通过 README.md 与 CHANGELOG.md 自动注入（见 build.gradle.kts 的 pluginConfiguration 块）。 -->

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Xidl" implementationClass="com.wps.cloud.xidl.language.XidlFileType" fieldName="INSTANCE"
                  language="Xidl" extensions="xidl"/>

        <lang.syntaxHighlighterFactory language="Xidl"
                                       implementationClass="com.wps.cloud.xidl.language.highlighting.XidlSyntaxHighlighterFactory"/>

        <colorSettingsPage implementation="com.wps.cloud.xidl.language.highlighting.ColorSettingPage"/>

        <lang.parserDefinition language="Xidl" implementationClass="com.wps.cloud.xidl.language.XidlParserDefinition"/>

        <completion.contributor
            language="Xidl"
            implementationClass="com.wps.cloud.xidl.language.completion.XidlCompletionContributor"/>

        <lang.commenter
            language="Xidl"
            implementationClass="com.wps.cloud.xidl.language.commenter.XidlCommenter"/>

        <lang.braceMatcher language="Xidl"
                           implementationClass="com.wps.cloud.xidl.language.brace.XidlBraceMatcher"/>

        <annotator
            language="Xidl"
            implementationClass="com.wps.cloud.xidl.language.annotator.XidlAnnotator"/>

        <lang.foldingBuilder
            language="Xidl"
            implementationClass="com.wps.cloud.xidl.language.folding.XidlFoldingBuilder"/>

        <langCodeStyleSettingsProvider
            implementation="com.wps.cloud.xidl.language.formatting.XidlLanguageCodeStyleSettingsProvider"/>

        <!-- 导航展示提供者 -->
        <itemPresentationProvider
            forClass="com.wps.cloud.xidl.language.psi.XidlSchemaName"
            implementationClass="com.wps.cloud.xidl.language.navigation.XidlSchemaPresentationProvider"/>


        <!-- 代码格式化 (缩进 / 空格 / { } 换行 / ; 后换行) -->
        <lang.formatter
            language="Xidl"
            implementationClass="com.wps.cloud.xidl.language.formatting.XidlFormattingModelBuilder"/>

<!-- 已废弃: 改用 BNF 里 anno_string + XidlAnnoStringMixin 方案, 更可靠 -->
<!--        <psi.referenceContributor language="Xidl"-->
<!--                                  implementation="com.wps.cloud.xidl.language.reference.XidlReferenceContributor"/>-->

        <lang.findUsagesProvider language="Xidl"
                implementationClass="com.wps.cloud.xidl.language.reference.XidlFindUsageProvider"/>

        <lang.quoteHandler language="Xidl"
                           implementationClass="com.wps.cloud.xidl.language.quote.XidlQuoteHandler"/>

        <lang.elementManipulator forClass="com.wps.cloud.xidl.language.psi.impl.XidlTypeReferenceImpl"
                                 implementationClass="com.wps.cloud.xidl.language.reference.XidlTypeReferenceManipulator"/>

        <additionalTextAttributes scheme="default" file="colorSchemes/xidlDefault.xml"/>

<!--        <include.provider implementation="com.wps.cloud.xidl.language.include.XidlFileIncludeProvider"/>-->
    </extensions>
</idea-plugin>
